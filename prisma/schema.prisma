generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GraduateStatus {
  EMPLOYE
  ENTREPRENEUR
  EN_RECHERCHE
  ETUDES
}

model GraduateResponse {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  graduationYear Int
  department     String
  status         GraduateStatus
  salaryRange    String
  timeToFirstJob Int
  topSkill       String

  @@map("graduate_responses")
}
