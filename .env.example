# ============================================================
#  AlumniPath — Variables d'environnement (Neon + Vercel)
#  Copier en .env.local pour le développement local
# ============================================================

# URL pooled Neon (pour les requêtes app — via PgBouncer)
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.neon.tech/[dbname]?sslmode=require&pgbouncer=true&connect_timeout=15"

# URL directe Neon (pour prisma db push / migrate uniquement)
DIRECT_URL="postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require"

NODE_ENV="development"
